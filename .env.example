# Copy to .env for local development or configure these values in the hosting panel.
# Do not commit real credentials or tokens.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
ADMIN_JWT_SECRET="replace-with-a-long-random-secret-at-least-32-characters"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Production hosts usually provide these values.
NODE_ENV="development"
PORT=3000
HOSTNAME="127.0.0.1"

# Local first-admin bootstrap for npm run seed:cms.
# Change these values before using the seed on any shared or production database.
CREATE_ADMIN_EMAIL="admin@realcapita.local"
CREATE_ADMIN_PASSWORD="ChangeMeBeforeProduction123!"
CREATE_ADMIN_NAME="Super Admin"
CREATE_ADMIN_OVERWRITE=false
