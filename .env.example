# Copy to .env for local development or configure these values in the hosting panel.
# Do not commit real credentials or tokens.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
ADMIN_JWT_SECRET="replace-with-a-long-random-secret"
NEXT_PUBLIC_SITE_URL="https://example.com"

# Optional first-admin bootstrap. Set temporarily when running npm run admin:create.
CREATE_ADMIN_EMAIL=
CREATE_ADMIN_PASSWORD=
CREATE_ADMIN_NAME=
CREATE_ADMIN_OVERWRITE=false
